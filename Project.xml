<?xml version="1.0" encoding="utf-8"?>
<project>
        <!-- _________________________ Application Settings _________________________ -->
        <app title="FNF: Psych Engine Mobile" file="PsychEngine-Mobile"
                packageName="com.brenninho.psychengine.mobile"
                package="com.brenninho.psychengine.mobile"
                main="Main" version="1.0.0" company="Brenninho-Crew" />

        <!-- ______________________ PSYCH ENGINE CUSTOMIZATION ______________________ -->
        <!-- Mobile: Mods permitidos, Lua/Hscript desabilitados para performance -->
        <define name="MODS_ALLOWED" if="android" />
        <define name="ACHIEVEMENTS_ALLOWED" />
        <define name="TRANSLATIONS_ALLOWED" />
        
        <!-- Mobile optimizations -->
        <define name="MULTITHREADED_LOADING" />
        <define name="SHOW_LOADING_SCREEN" />
        
        <!-- ====================== MOBILE CORE CONFIGURATION ====================== -->
        <define name="MOBILE_DATA" if="mobile" />
        <define name="TOUCH_CONTROLS" if="mobile" />
        
        <!-- OBB Support: indica que assets serão lidos do .obb -->
        <define name="OBB_SUPPORT" if="android" />
        
        <!-- Video support (opcional, pode causar lag em dispositivos mais fracos) -->
        <!-- <define name="VIDEOS_ALLOWED" if="android" unless="lowEndDevice" /> -->
        
        <!-- ____________________________ Window Settings ___________________________ -->
        <window width="1280" height="720" fps="60" background="#000000" 
                hardware="true" vsync="false" allow-high-dpi="true" />
        <window if="mobile" orientation="landscape" fullscreen="true" width="0" height="0"
                resizable="false" allow-shaders="true" require-shaders="false" 
                allow-high-dpi="true" />
        
        <!-- ====================== Android SDK Configuration ====================== -->
        <section if="android">
                <set name="ANDROID_TARGET_SDK_VERSION" value="34" />
                <set name="ANDROID_MIN_SDK_VERSION"    value="21" />
                <set name="ANDROID_BUILD_SDK_VERSION"  value="34" />
        </section>
        
        <!-- ====================== Android Permissions ============================ -->
        <section if="android">
                <!-- Storage permissions para ler mods do armazenamento externo -->
                <dependency name="READ_EXTERNAL_STORAGE" 
                            value="android.permission.READ_EXTERNAL_STORAGE" if="MODS_ALLOWED" />
                <dependency name="WRITE_EXTERNAL_STORAGE" 
                            value="android.permission.WRITE_EXTERNAL_STORAGE" if="MODS_ALLOWED" />
                
                <!-- Android 13+ permission for media files -->
                <dependency name="READ_MEDIA_IMAGES" 
                            value="android.permission.READ_MEDIA_IMAGES" if="MODS_ALLOWED" />
                <dependency name="READ_MEDIA_AUDIO" 
                            value="android.permission.READ_MEDIA_AUDIO" if="MODS_ALLOWED" />
                
                <!-- Internet para possíveis updates futuros -->
                <dependency name="INTERNET" value="android.permission.INTERNET" />
                <!-- Vibrate para feedback tátil nos controles touch -->
                <dependency name="VIBRATE" value="android.permission.VIBRATE" />
        </section>
        
        <!-- _____________________________ Path Settings ____________________________ -->
        <set name="BUILD_DIR" value="export/release" unless="debug" />
        <classpath name="source" />
        
        <!-- __________________________ Game Assets & OBB Setup _____________________ -->
        
        <!--
            CONFIGURAÇÃO PARA ANDROID COM OBB:
            
            O diretório "shared" será empacotado no APK (pequeno, apenas código).
            Os diretórios pesados (songs, week_assets, videos) vão para o OBB.
            
            Para gerar o OBB:
            1. Após compilar, use o script expansion-files do Android SDK
            2. Ou use a ferramenta "obb-maker" disponível em tools/
        -->
        
        <!-- Assets essenciais que ficam no APK (fontes, configurações, UI) -->
        <assets path="assets/fonts" embed="true" />
        <assets path="assets/embed" embed="true" />
        <assets path="assets/shared" embed="true" exclude="*.ogg,*.mp3,*.wav,*.png" />
        
        <!-- Assets que vão para o OBB (músicas, imagens grandes, vídeos) -->
        <section if="OBB_SUPPORT">
            <!-- Estes paths serão lidos do OBB em runtime pelo Paths.hx -->
            <assets path="assets/songs" embed="false" rename="obb/assets/songs" />
            <assets path="assets/week_assets" embed="false" rename="obb/assets/week_assets" />
            <assets path="assets/videos" embed="false" rename="obb/assets/videos" if="VIDEOS_ALLOWED" />
        </section>
        
        <!-- Fallback para builds sem OBB (modo debug) -->
        <section unless="OBB_SUPPORT">
            <assets path="assets/songs" exclude="*.ogg" if="web" />
            <assets path="assets/songs" exclude="*.mp3" unless="web" />
            <assets path="assets/week_assets" rename="assets" exclude="*.ogg" if="web" />
            <assets path="assets/week_assets" rename="assets" exclude="*.mp3" unless="web" />
            <assets path="assets/videos" if="VIDEOS_ALLOWED" />
        </section>
        
        <!-- __________________________ Mods Configuration __________________________ -->
        
        <!--
            MODS NO ANDROID:
            
            Prioridade de busca (implementar no Paths.hx):
            1. /storage/emulated/0/Android/data/com.brenninho.psychengine.mobile/files/mods/
            2. /storage/emulated/0/FNF-Mods/ (fallback para fácil acesso)
            3. /sdcard/FNF-Mods/
            4. OBB:/assets/mods/ (mods base embutidos no OBB)
            
            O diretório "example_mods" NÃO é embutido no APK para economizar espaço.
            Em vez disso, os mods exemplo serão distribuídos via OBB ou como download separado.
        -->
        
        <section if="MODS_ALLOWED android">
            <!-- Não embute mods no APK -->
            <assets path='example_mods' embed='false' if="debug" />
            
            <!-- Arquivo de lista de mods (pode ser gerado dinamicamente) -->
            <assets path='list.txt' rename='modsList.txt' embed='false' />
            
            <!-- Configuração para leitura de mods do storage -->
            <define name="MODS_EXTERNAL_STORAGE" />
            <define name="MODS_EXTERNAL_PATH" value="FNF-Mods" />
            <define name="MODS_EXTERNAL_FALLBACK" value="Android/data/com.brenninho.psychengine.mobile/files/mods" />
        </section>
        
        <!-- _______________________________ Libraries ______________________________ -->
        
        <!-- Core libraries (versões estáveis) -->
        <haxelib name="flixel" version="5.6.1" />
        <haxelib name="flixel-addons" version="3.2.2" />
        <haxelib name="tjson" version="1.4.0" />
        <haxelib name="flxanimate" />
        
        <!-- Mobile-specific extensions -->
        <haxelib name="extension-androidtools" if="android" />
        
        <!-- Optional: Video support (comente se causar problemas) -->
        <!-- <haxelib name="hxvlc" if="VIDEOS_ALLOWED android" version="2.0.1" /> -->
        
        <!-- Performance: desabilitar features pesadas no mobile -->
        <haxedef name="NO_PRECOMPILED_HEADERS" if="android" />
        
        <!-- Debug tools (apenas debug builds) -->
        <haxelib name="hxcpp-debug-server" if="debug" />
        
        <!-- ______________________________ Haxedefines _____________________________ -->
        
        <!-- Mobile-specific optimizations -->
        <haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />
        <haxedef name="MOBILE_TOUCH_CONTROLS" if="TOUCH_CONTROLS" />
        
        <!-- Touch control settings -->
        <haxedef name="TOUCH_CONTROL_SIZE" value="200" if="TOUCH_CONTROLS" />
        <haxedef name="TOUCH_CONTROL_OPACITY" value="0.6" if="TOUCH_CONTROLS" />
        <haxedef name="VIRTUAL_PAD_DEADZONE" value="0.3" if="TOUCH_CONTROLS" />
        
        <!-- Memory optimizations for low-end devices -->
        <haxedef name="TEXTURE_CACHE_SIZE" value="256" if="android" />
        <haxedef name="MAX_SOUNDS_CACHED" value="32" if="android" />
        
        <!-- Disable unnecessary desktop features -->
        <haxedef name="FLX_NO_MOUSE" if="android" />
        <haxedef name="FLX_NO_KEYBOARD" if="android" />
        <haxedef name="FLX_NO_GAMEPAD" if="android" />
        
        <!-- Crash handling -->
        <haxedef name="CRASH_HANDLER" if="android release" />
        <haxedef name="HXCPP_CHECK_POINTER" if="CRASH_HANDLER" />
        <haxedef name="HXCPP_STACK_TRACE" if="CRASH_HANDLER" />
        
        <!-- __________________________ Custom Metadata _____________________________ -->
        
        <!-- Meta-informação para o AndroidManifest.xml -->
        <meta if="android" title="com.brenninho.psychengine.mobile.metadata.MODS_PATH" 
              content="/storage/emulated/0/FNF-Mods" />
        <meta if="android" title="com.brenninho.psychengine.mobile.metadata.OBB_MAIN_VERSION" 
              content="1" />
        <meta if="android" title="com.brenninho.psychengine.mobile.metadata.OBB_PATCH_VERSION" 
              content="0" />
        
        <!-- _________________________________ Icons _________________________________ -->
        <icon path="art/icons/icon16.png" size='16' if="android" />
        <icon path="art/icons/icon32.png" size='32' if="android" />
        <icon path="art/icons/icon64.png" size='64' if="android" />
        <icon path="art/icons/icon128.png" size='128' if="android" />
        <icon path="art/icons/icon256.png" size='256' if="android" />
        <icon path="art/icons/iconOG.png" if="android" />
</project>