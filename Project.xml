<?xml version="1.0" encoding="utf-8"?>
<project>
        <!-- _________________________ Application Settings _________________________ -->
        <app title="FNF: Psych Engine" file="PsychEngine-Mobile"
                packageName="com.brenninho.psychengine.mobile"
                package="com.brenninho.psychengine.mobile"
                main="Main" version="1.0.0" company="Brenninho-Crew" />

        <!-- ______________________ PSYCH ENGINE CUSTOMIZATION ______________________ -->
        <define name="MODS_ALLOWED" if="android" />
        <define name="ACHIEVEMENTS_ALLOWED" />
        <define name="TRANSLATIONS_ALLOWED" />
        
        <!-- Mobile optimizations -->
        <define name="MULTITHREADED_LOADING" />
        <define name="SHOW_LOADING_SCREEN" />
        
        <!-- ====================== MOBILE CORE CONFIGURATION ====================== -->
        <define name="MOBILE_DATA" if="mobile" />
        <define name="TOUCH_CONTROLS" if="mobile" />
        
        <!-- OBB Support + Google Play Licensing -->
        <define name="OBB_SUPPORT" if="android" />
        <define name="GOOGLE_PLAY_LICENSING" if="android release" />
        
        <!-- Video support (mantido, mas otimizado) -->
        <define name="VIDEOS_ALLOWED" if="android" />
        
        <!-- GAMEPAD SUPORTADO NATIVAMENTE PELO FLIXEL -->
        <!-- Flixel tem suporte nativo a gamepad, não precisa de extensão extra -->
        <haxedef name="FLX_GAMEPAD_API" if="android" />
        
        <!-- ____________________________ Window Settings ___________________________ -->
        <window width="1280" height="720" fps="60" background="#000000" 
                hardware="true" vsync="false" allow-high-dpi="true" />
        <window if="mobile" orientation="landscape" fullscreen="true" width="0" height="0"
                resizable="false" allow-shaders="true" require-shaders="false" 
                allow-high-dpi="true" />
        
        <!-- ====================== Android SDK Configuration ====================== -->
        <section if="android">
                <set name="ANDROID_TARGET_SDK_VERSION" value="34" />
                <set name="ANDROID_MIN_SDK_VERSION"    value="21" />
                <set name="ANDROID_BUILD_SDK_VERSION"  value="34" />
        </section>
        
        <!-- ====================== Android Permissions ============================ -->
        <section if="android">
                <!-- Permissões de armazenamento - DETECÇÃO AUTOMÁTICA -->
                <define name="STORAGE_PERMISSIONS" />
                
                <!-- Permissões para Android 10-12 -->
                <dependency name="READ_EXTERNAL_STORAGE" 
                            value="android.permission.READ_EXTERNAL_STORAGE" if="MODS_ALLOWED" />
                <dependency name="WRITE_EXTERNAL_STORAGE" 
                            value="android.permission.WRITE_EXTERNAL_STORAGE" if="MODS_ALLOWED" />
                
                <!-- Permissões para Android 13+ (Media Access) -->
                <dependency name="READ_MEDIA_IMAGES" 
                            value="android.permission.READ_MEDIA_IMAGES" if="MODS_ALLOWED" />
                <dependency name="READ_MEDIA_AUDIO" 
                            value="android.permission.READ_MEDIA_AUDIO" if="MODS_ALLOWED" />
                <dependency name="READ_MEDIA_VIDEO" 
                            value="android.permission.READ_MEDIA_VIDEO" if="MODS_ALLOWED" />
                
                <!-- Permissão para Android 14+ (Media Access) -->
                <dependency name="READ_MEDIA_VISUAL_USER_SELECTED" 
                            value="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" if="MODS_ALLOWED" />
                
                <!-- Internet para licenciamento Google Play -->
                <dependency name="INTERNET" value="android.permission.INTERNET" />
                <dependency name="ACCESS_NETWORK_STATE" value="android.permission.ACCESS_NETWORK_STATE" />
                
                <!-- Feedback tátil -->
                <dependency name="VIBRATE" value="android.permission.VIBRATE" />
        </section>
        
        <!-- ====================== Google Play Licensing ========================== -->
        <section if="GOOGLE_PLAY_LICENSING">
                <!-- Google Play Licensing Library -->
                <dependency name="com.android.vending.licensing"
                            value="com.google.android.vending.licensing.Library" />
                
                <!-- Meta-data para a licensing policy -->
                <meta if="android" 
                      title="com.google.android.vending.licensing.LICENSE_POLICY" 
                      content="com.google.android.vending.licensing.StrictPolicy" />
                
                <!-- Base64 da sua public key (obtida no Google Play Console) -->
                <define name="GOOGLE_PLAY_PUBLIC_KEY" value="SUA_CHAVE_PUBLICA_AQUI" />
        </section>
        
        <!-- _____________________________ Path Settings ____________________________ -->
        <set name="BUILD_DIR" value="export/release" unless="debug" />
        <classpath name="source" />
        
        <!-- __________________________ Assets & OBB Setup _________________________ -->
        
        <!-- Assets essenciais no APK -->
        <assets path="assets/fonts" embed="true" />
        <assets path="assets/embed" embed="true" />
        <assets path="assets/shared" embed="true" exclude="*.ogg,*.mp3,*.wav,*.png,*.jpg,*.jpeg" />
        
        <!-- Assets que vão para OBB -->
        <section if="OBB_SUPPORT">
            <assets path="assets/songs" embed="false" rename="obb/assets/songs" />
            <assets path="assets/week_assets" embed="false" rename="obb/assets/week_assets" />
            <assets path="assets/videos" embed="false" rename="obb/assets/videos" if="VIDEOS_ALLOWED" />
            <assets path="assets/shared/images" embed="false" rename="obb/assets/shared/images" />
            <assets path="assets/shared/music" embed="false" rename="obb/assets/shared/music" />
            <assets path="assets/shared/sounds" embed="false" rename="obb/assets/shared/sounds" />
        </section>
        
        <!-- Fallback para builds sem OBB -->
        <section unless="OBB_SUPPORT">
            <assets path="assets/songs" />
            <assets path="assets/week_assets" rename="assets" />
            <assets path="assets/videos" if="VIDEOS_ALLOWED" />
            <assets path="assets/shared/images" />
            <assets path="assets/shared/music" />
            <assets path="assets/shared/sounds" />
        </section>
        
        <!-- __________________________ Mods Configuration __________________________ -->
        
        <!--
            SISTEMA AUTOMÁTICO DE DETECÇÃO DE PASTA EXTERNA
            
            O Paths.hx irá verificar as seguintes localizações em ordem:
            
            1. PRIMARY EXTERNAL (Android/data) - Recomendado
               /storage/emulated/0/Android/data/com.brenninho.psychengine.mobile/files/mods/
            
            2. LEGACY EXTERNAL (SD Card root)
               /storage/emulated/0/FNF-Mods/
               /storage/AAAA-AAAA/FNF-Mods/ (SD Card externo)
            
            3. OBB FALLBACK
               /obb/assets/mods/
            
            4. INTERNAL FALLBACK
               /data/data/com.brenninho.psychengine.mobile/files/mods/
        -->
        
        <section if="MODS_ALLOWED android">
            <!-- Não embute mods no APK (exceto debug) -->
            <assets path='example_mods' embed='false' if="debug" />
            
            <!-- Arquivo de lista de mods (gerado dinamicamente) -->
            <assets path='list.txt' rename='modsList.txt' embed='false' />
            
            <!-- Configurações para detecção automática -->
            <define name="MODS_AUTO_DETECT" />
            <define name="MODS_PRIMARY_PATH" value="Android/data/com.brenninho.psychengine.mobile/files/mods" />
            <define name="MODS_LEGACY_PATH" value="FNF-Mods" />
            
            <!-- Meta-data para o AndroidManifest.xml -->
            <meta if="android" 
                  title="com.brenninho.psychengine.mobile.mods.AUTO_DETECT" 
                  content="true" />
            <meta if="android" 
                  title="com.brenninho.psychengine.mobile.mods.PRIMARY_PATH" 
                  content="${MODS_PRIMARY_PATH}" />
        </section>
        
        <!-- _______________________________ Libraries ______________________________ -->
        
        <!-- Core libraries -->
        <haxelib name="flixel" version="5.6.1" />
        <haxelib name="flixel-addons" version="3.2.2" />
        <haxelib name="tjson" version="1.4.0" />
        <haxelib name="flxanimate" />
        
        <!-- Android extensions (apenas essentials) -->
        <haxelib name="extension-androidtools" if="android" />
        
        <!-- Video support -->
        <haxelib name="hxvlc" if="VIDEOS_ALLOWED android" version="2.0.1" />
        
        <!-- Google Play Licensing (se ativado) -->
        <haxelib name="extension-googleplayservices" if="GOOGLE_PLAY_LICENSING" />
        
        <!-- Performance -->
        <haxedef name="NO_PRECOMPILED_HEADERS" if="android" />
        
        <!-- ______________________________ Haxedefines _____________________________ -->
        
        <!-- Mobile optimizations -->
        <haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />
        <haxedef name="MOBILE_TOUCH_CONTROLS" if="TOUCH_CONTROLS" />
        
        <!-- Touch control settings -->
        <haxedef name="TOUCH_CONTROL_SIZE" value="180" if="TOUCH_CONTROLS" />
        <haxedef name="TOUCH_CONTROL_OPACITY" value="0.7" if="TOUCH_CONTROLS" />
        <haxedef name="VIRTUAL_PAD_DEADZONE" value="0.25" if="TOUCH_CONTROLS" />
        
        <!-- GAMEPAD SETTINGS (nativo do Flixel) -->
        <haxedef name="GAMEPAD_DEADZONE" value="0.2" if="android" />
        <haxedef name="FLX_GAMEPAD_API" if="android" />
        
        <!-- Memory optimizations -->
        <haxedef name="TEXTURE_CACHE_SIZE" value="256" if="android" />
        <haxedef name="MAX_SOUNDS_CACHED" value="48" if="android" />
        <haxedef name="MAX_VIDEO_MEMORY" value="128" if="android VIDEOS_ALLOWED" />
        
        <!-- Disable apenas features desktop -->
        <haxedef name="FLX_NO_MOUSE" if="android" />
        <haxedef name="FLX_NO_KEYBOARD" if="android" />
        
        <!-- Crash handling -->
        <haxedef name="CRASH_HANDLER" if="android release" />
        <haxedef name="HXCPP_STACK_TRACE" if="CRASH_HANDLER" />
        
        <!-- __________________________ AndroidManifest Meta ________________________ -->
        
        <!-- Google Play Licensing verification -->
        <section if="GOOGLE_PLAY_LICENSING">
            <meta if="android" 
                  title="com.google.android.vending.licensing.PUBLIC_KEY" 
                  content="${GOOGLE_PLAY_PUBLIC_KEY}" />
        </section>
        
        <!-- OBB configuration -->
        <meta if="android" 
              title="com.brenninho.psychengine.mobile.obb.MAIN_VERSION" 
              content="1" />
        <meta if="android" 
              title="com.brenninho.psychengine.mobile.obb.PATCH_VERSION" 
              content="0" />
        
        <!-- _________________________________ Icons _________________________________ -->
        <icon path="art/icons/icon16.png" size='16' if="android" />
        <icon path="art/icons/icon32.png" size='32' if="android" />
        <icon path="art/icons/icon64.png" size='64' if="android" />
        <icon path="art/icons/icon128.png" size='128' if="android" />
        <icon path="art/icons/icon256.png" size='256' if="android" />
        <icon path="art/icons/icon512.png" size='512' if="android" />
        <icon path="art/icons/iconOG.png" if="android" />
</project>